// --- Storefront
// --- Find your Storefront API access token under:
// ----- https://admin.shopify.com/store/{STOREFRONT}/settings/apps/development/{APP_ID}/api_credentials

STOREFRONT_DOMAIN = <INSERT_STOREFRONT_DOMAIN>
STOREFRONT_ACCESS_TOKEN = <INSERT_STOREFRONT_ACCESS_TOKEN>
STOREFRONT_MERCHANT_IDENTIFIER = <INSERT_STOREFRONT_MERCHANT_IDENTIFIER>

// --- Customer Account API (optional, required for authenticated checkout)
// --- CUSTOMER_ACCOUNT_API_CLIENT_ID:
// ----- Found under Headless app > Customer Account API > Application setup > Client ID
// ----- https://admin.shopify.com/store/{STOREFRONT}/settings/apps/development/{APP_ID}
// --- CUSTOMER_ACCOUNT_API_SHOP_ID:
// ----- The numeric Shop ID visible in Settings > Customer accounts > Customer Account API
// ----- https://admin.shopify.com/store/{STOREFRONT}/settings/customer_accounts
// ----- Also visible in the shop admin URL: https://admin.shopify.com/store/{STOREFRONT} > Settings
CUSTOMER_ACCOUNT_API_CLIENT_ID = <INSERT_CLIENT_ID>
CUSTOMER_ACCOUNT_API_SHOP_ID = <INSERT_SHOP_ID>

// --- Buyer preference data
EMAIL = test-checkout-sdk@shopify.com

FIRST_NAME = Test
LAST_NAME = Test

ADDRESS_1 = The Cloak & Dagger
ADDRESS_2 = 1st Street Southeast
CITY = Calgary
COUNTRY = CA
PROVINCE = AB
ZIP = T1X 0L3
PHONE = +155565708743

API_VERSION = 2025-07
